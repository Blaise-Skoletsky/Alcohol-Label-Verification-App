# Local development and Docker Compose configuration.
# Copy this file to .env before running the app, then choose either local or openrouter mode.

# Model provider: local or openrouter
PROVIDER_MODE=local

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL_PRIMARY=google/gemini-3.1-flash-lite-preview
OPENROUTER_MODEL_FALLBACKS=google/gemini-2.5-flash-lite,google/gemini-2.5-flash
OPENROUTER_TIMEOUT_SECONDS=30
OPENROUTER_HTTP_REFERER=http://localhost:7001
OPENROUTER_APP_TITLE=Alcohol Label Verification App

# Local OpenAI-compatible model server, used only when PROVIDER_MODE=local.
# Docker uses host.docker.internal to reach Ollama running on the host machine.
LOCAL_MODEL_BASE_URL=http://host.docker.internal:11434/v1/chat/completions
LOCAL_MODEL_NAME=qwen2.5vl-alv:latest

# Runtime
ENVIRONMENT=development
LOG_LEVEL=info

# Services
BACKEND_HOST=0.0.0.0
PORT=8000
FRONTEND_PORT=5173
FRONTEND_URL=http://localhost:7001
PUBLIC_API_BASE_URL=http://localhost:7001
CORS_ORIGINS=http://localhost:7001,http://127.0.0.1:7001,http://localhost:5173,http://127.0.0.1:5173
