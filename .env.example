# Local development and Docker Compose configuration.
# A .env file is optional for local demo mode.
# Copy this file to .env only when enabling OpenRouter or other real credentials.

# Model provider
MODEL_PROVIDER=mock

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL_PRIMARY=google/gemini-3.5-flash
OPENROUTER_MODEL_FALLBACKS=google/gemini-3.1-flash-lite,openai/gpt-4.1-mini,anthropic/claude-haiku-4.5
OPENROUTER_TIMEOUT_SECONDS=5
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_APP_TITLE=Alcohol Label Verification App

# Runtime
ENVIRONMENT=development
LOG_LEVEL=info

# Services
BACKEND_HOST=0.0.0.0
PORT=8000
FRONTEND_PORT=5173
FRONTEND_URL=http://localhost:5173
PUBLIC_API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173

# Limits
MAX_UPLOAD_MB=10
BATCH_CONCURRENCY=5
MAX_BATCH_LABELS=400
